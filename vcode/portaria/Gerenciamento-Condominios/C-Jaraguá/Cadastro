-- Criando a tabela de Unidades (Torres e Apartamentos)
CREATE TABLE unidades (
    id SERIAL PRIMARY KEY,
    torre VARCHAR(20) NOT NULL,          -- Ex: "Torre 1", "Edifício Jaraguá"
    apartamento VARCHAR(10) NOT NULL,    -- Ex: "44", "12-2ad"
    nome_morador_responsavel VARCHAR(100), -- LGPD: Acesso restrito à portaria
    contato_interfone VARCHAR(20),       -- Referência direta para a portaria
    possui_veiculo BOOLEAN NOT NULL DEFAULT FALSE, -- O filtro sim/não que você pediu
    status_tag VARCHAR(30) DEFAULT 'Nao se aplica' -- 'Pendente', 'Emitida' ou 'Nao se aplica'
);
